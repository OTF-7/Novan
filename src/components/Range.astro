---
import { Image } from "astro:assets";
/* TODO: per-SKU cut-outs coming from the client — 500ml duplicated for now */
import cutout from "../assets/bottle-cutout-500.png";
import hoverTable from "../assets/lifestyle-table.jpg";
import hoverGlass from "../assets/lifestyle-glass.jpg";
import hoverStill from "../assets/lifestyle-still.jpg";
import hoverDrape from "../assets/lifestyle-drape.jpg";

/* Real Novan SKUs per the 2025 brand profile:
   small 200ml & 330ml · medium 500ml & 1L · large 1.5L & 5L */
const products = [
  {
    delay: "",
    name: "Novan 330ml",
    nameAr: "نوفان 330 مل",
    meta: "330 ML · ALSO IN 200 ML",
    metaAr: "330 مل · متوفر أيضاً 200 مل",
    hover: hoverTable,
    hoverAlt: "Novan bottles on a shared table",
    desc: "The grab-and-go. Sized for meetings, school bags and journeys.",
    descAr: "الرفيق السريع. بحجم مثالي للاجتماعات والحقائب والترحال.",
    tag: "On the move",
    tagAr: "للتنقّل",
  },
  {
    delay: "d1",
    name: "Novan 500ml",
    nameAr: "نوفان 500 مل",
    meta: "500 ML · ALSO IN 1 L",
    metaAr: "500 مل · متوفر أيضاً 1 لتر",
    hover: hoverGlass,
    hoverAlt: "Novan poured into a glass with fresh mint",
    desc: "Our everyday bottle — the one that lives on every desk.",
    descAr: "عبوتنا اليومية — الحاضرة على كل مكتب.",
    tag: "Everyday",
    tagAr: "يومي",
  },
  {
    delay: "d2",
    name: "Novan 1.5L",
    nameAr: "نوفان 1.5 لتر",
    meta: "1.5 L · PET",
    metaAr: "1.5 لتر · PET",
    hover: hoverStill,
    hoverAlt: "Novan 1.5L on a calm blue table",
    desc: "For the table and the family fridge. Shared, refilled, loved.",
    descAr: "لمائدة العائلة وثلاجة المنزل. تُشارك وتُملأ ويُحبّها الجميع.",
    tag: "At home",
    tagAr: "للمنزل",
  },
  {
    delay: "d3",
    name: "Novan 5L",
    nameAr: "نوفان 5 لتر",
    meta: "5 L · FAMILY",
    metaAr: "5 لتر · عائلي",
    hover: hoverDrape,
    hoverAlt: "Novan bottles gathered on a draped cloth",
    desc: "The family reserve — for kitchens, gatherings and generous pours.",
    descAr: "مخزون العائلة — للمطابخ والتجمعات والضيافة الكريمة.",
    tag: "Family size",
    tagAr: "حجم عائلي",
  },
] as const;
---

<section class="range section-pad" id="range">
  <div class="wrap">
    <div class="range-head">
      <div class="sec-head">
        <span class="kicker reveal" data-en="The Range" data-ar="منتجاتنا">The Range</span>
        <h2 class="reveal d1">
          <span data-en="A size for every " data-ar="حجم لكل ">A size for every </span><span
            class="accent"
            data-en="moment."
            data-ar="لحظة.">moment.</span
          >
        </h2>
      </div>
      <a href="#contact" class="link-arrow reveal d2"
        ><span data-en="Request the full catalogue" data-ar="اطلب الكتالوج الكامل">Request the full catalogue</span>
        <span class="arrow">→</span></a
      >
    </div>

    <div class="range-grid">
      {
        products.map((p) => (
          <article class={`product reveal ${p.delay}`}>
            <div class="product-img">
              <div class="bottle-art" aria-hidden="true">
                <Image src={cutout} alt="" widths={[320, 560]} sizes="(max-width: 560px) 45vw, 320px" />
              </div>
              <Image
                class="cover alt"
                loading="lazy"
                widths={[480, 700]}
                sizes="(max-width: 560px) 50vw, (max-width: 1080px) 45vw, 320px"
                alt={p.hoverAlt}
                src={p.hover}
              />
            </div>
            <div class="pname" data-en={p.name} data-ar={p.nameAr}>
              {p.name}
            </div>
            <div class="pmeta" data-en={p.meta} data-ar={p.metaAr}>
              {p.meta}
            </div>
            <p class="pdesc" data-en={p.desc} data-ar={p.descAr}>
              {p.desc}
            </p>
            <span class="ptag" data-en={p.tag} data-ar={p.tagAr}>
              {p.tag}
            </span>
          </article>
        ))
      }
    </div>
  </div>
</section>
