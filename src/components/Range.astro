---
import BottleArt from "./BottleArt.astro";

const products = [
  {
    delay: "",
    variant: "330",
    name: "Novan 330ml",
    nameAr: "نوفان 330 مل",
    meta: "330 ML · PET",
    metaAr: "330 مل · PET",
    alt: "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=700&q=80",
    altAlt: "Novan 330ml in use",
    desc: "The grab-and-go. Sized for meetings, gyms and journeys.",
    descAr: "الرفيق السريع. بحجم مثالي للاجتماعات والنوادي والترحال.",
    tag: "On the move",
    tagAr: "للتنقّل",
  },
  {
    delay: "d1",
    variant: "600",
    name: "Novan 600ml",
    nameAr: "نوفان 600 مل",
    meta: "600 ML · PET",
    metaAr: "600 مل · PET",
    alt: "https://images.unsplash.com/photo-1548839140-29a749e1cf4d?auto=format&fit=crop&w=700&q=80",
    altAlt: "Novan 600ml poured",
    desc: "Our everyday bottle — the one that lives on every desk.",
    descAr: "عبوتنا اليومية — الحاضرة على كل مكتب.",
    tag: "Everyday",
    tagAr: "يومي",
  },
  {
    delay: "d2",
    variant: "1500",
    name: "Novan 1.5L",
    nameAr: "نوفان 1.5 لتر",
    meta: "1.5 L · PET",
    metaAr: "1.5 لتر · PET",
    alt: "https://images.unsplash.com/photo-1553564552-02656d6a2390?auto=format&fit=crop&w=700&q=80",
    altAlt: "Novan 1.5L on the table",
    desc: "For the table and the family fridge. Shared, refilled, loved.",
    descAr: "لمائدة العائلة وثلاجة المنزل. تُشارك وتُملأ ويُحبّها الجميع.",
    tag: "At home",
    tagAr: "للمنزل",
  },
  {
    delay: "d3",
    variant: "19000",
    name: "Novan 19L",
    nameAr: "نوفان 19 لتر",
    meta: "19 L · DISPENSER",
    metaAr: "19 لتر · برّاد",
    alt: "https://images.unsplash.com/photo-1521207418485-99c705420785?auto=format&fit=crop&w=700&q=80",
    altAlt: "Novan water from the dispenser",
    desc: "The office and home dispenser. Pure water, delivered to your door.",
    descAr: "عبوة المكتب والمنزل. مياه نقية تصل إلى بابك.",
    tag: "Dispenser",
    tagAr: "برّاد",
  },
] as const;
---

<section class="range section-pad" id="range">
  <div class="wrap">
    <div class="range-head">
      <div class="sec-head">
        <span class="kicker reveal" data-en="The Range" data-ar="منتجاتنا">The Range</span>
        <h2 class="reveal d1">
          <span data-en="A size for every " data-ar="حجم لكل ">A size for every </span><span
            class="accent"
            data-en="moment."
            data-ar="لحظة.">moment.</span
          >
        </h2>
      </div>
      <a href="#contact" class="link-arrow reveal d2"
        ><span data-en="Request the full catalogue" data-ar="اطلب الكتالوج الكامل">Request the full catalogue</span>
        <span class="arrow">→</span></a
      >
    </div>

    <div class="range-grid">
      {
        products.map((p) => (
          <article class={`product reveal ${p.delay}`}>
            <div class="product-img media">
              <div class="bottle-art" aria-hidden="true">
                <BottleArt variant={p.variant} />
              </div>
              <img class="cover alt" loading="lazy" alt={p.altAlt} src={p.alt} />
            </div>
            <div class="pname" data-en={p.name} data-ar={p.nameAr}>
              {p.name}
            </div>
            <div class="pmeta" data-en={p.meta} data-ar={p.metaAr}>
              {p.meta}
            </div>
            <p class="pdesc" data-en={p.desc} data-ar={p.descAr}>
              {p.desc}
            </p>
            <span class="ptag" data-en={p.tag} data-ar={p.tagAr}>
              {p.tag}
            </span>
          </article>
        ))
      }
    </div>
  </div>
</section>
