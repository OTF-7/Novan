---
import { Image } from "astro:assets";
import purityIce from "../assets/purity-ice.jpg";
---

<section class="process section-pad" id="process">
  <div class="wrap">
    <div class="sec-head center">
      <span class="kicker reveal" data-en="Purity" data-ar="النقاء">Purity</span>
      <h2 class="reveal d1">
        <span data-en="From the source, " data-ar="من المصدر، ">From the source, </span><span
          class="accent"
          data-en="to the seal."
          data-ar="إلى الختم.">to the seal.</span
        >
      </h2>
      <p
        class="reveal d2"
        data-en="Multi-stage filtration, UV purification and ozone treatment — verified by precise daily testing against international health standards, in our own laboratory."
        data-ar="ترشيح متعدد المراحل وتنقية بالأشعة فوق البنفسجية ومعالجة بالأوزون — تتحقق منها فحوصات دقيقة يومية وفق المواصفات الصحية العالمية في مختبرنا الخاص."
      >
        Multi-stage filtration, UV purification and ozone treatment — verified by precise daily testing
        against international health standards, in our own laboratory.
      </p>
    </div>

    <div class="process-visual media" data-fx="rise">
      <div class="ph" data-label="Cold. Clean. Sealed."></div>
      <Image
        src={purityIce}
        class="cover"
        loading="lazy"
        widths={[768, 1280, 1800]}
        sizes="(max-width: 880px) 100vw, 80vw"
        alt="A Novan bottle buried in crushed ice"
      />
    </div>

    <div class="process-grid">
      <div class="step reveal">
        <span class="ico"
          ><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
            ><path d="M12 2C12 2 5 9 5 14a7 7 0 0014 0c0-5-7-12-7-12z"></path></svg
          ></span
        >
        <h3 data-en="Sourced" data-ar="الاستخراج">Sourced</h3>
        <p
          data-en="Drawn from a protected deep aquifer beneath the highlands."
          data-ar="تُستخرج من طبقة جوفية عميقة محمية أسفل المرتفعات."
        >
          Drawn from a protected deep aquifer beneath the highlands.
        </p>
      </div>
      <div class="step reveal d1">
        <span class="ico"
          ><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
            ><path d="M3 4h18l-7 8v6l-4 2v-8z"></path></svg
          ></span
        >
        <h3 data-en="Filtered" data-ar="التنقية">Filtered</h3>
        <p
          data-en="Micro and reverse-osmosis filtration remove the finest impurities."
          data-ar="تنقية دقيقة وتناضح عكسي يزيلان أدق الشوائب."
        >
          Micro and reverse-osmosis filtration remove the finest impurities.
        </p>
      </div>
      <div class="step reveal d2">
        <span class="ico"
          ><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
            ><circle cx="12" cy="12" r="4"></circle><path
              d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"></path></svg
          ></span
        >
        <h3 data-en="Sterilised" data-ar="التعقيم">Sterilised</h3>
        <p
          data-en="UV and ozone treatment ensure water that is biologically pure."
          data-ar="معالجة بالأشعة فوق البنفسجية والأوزون لضمان نقاء بيولوجي تام."
        >
          UV and ozone treatment ensure water that is biologically pure.
        </p>
      </div>
      <div class="step reveal d3">
        <span class="ico"
          ><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
            ><path d="M9 2h6v4l-2 2v6a4 4 0 11-2 0V8L9 6z"></path></svg
          ></span
        >
        <h3 data-en="Sealed & tested" data-ar="الختم والفحص">Sealed &amp; tested</h3>
        <p
          data-en="Bottled on a sealed line and verified batch-by-batch in our lab."
          data-ar="تُعبّأ على خط محكم ويُتحقق منها دفعةً دفعة في مختبرنا."
        >
          Bottled on a sealed line and verified batch-by-batch in our lab.
        </p>
      </div>
    </div>
  </div>
</section>
