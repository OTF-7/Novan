<section class="sustain section-pad">
  <div class="wrap sustain-grid">
    <div class="sustain-body">
      <div class="sec-head">
        <span class="kicker reveal" data-en="Responsibility" data-ar="مسؤوليتنا">Responsibility</span>
        <h2 class="reveal d1">
          <span data-en="Lighter on the " data-ar="أخفّ على ">Lighter on the </span><span
            class="accent"
            data-en="land we love."
            data-ar="الأرض التي نحب.">land we love.</span
          >
        </h2>
        <p
          class="reveal d2"
          data-en="The mountains gave us this water. Protecting them is not a campaign — it is the condition of everything we make."
          data-ar="الجبال منحتنا هذه المياه، وحمايتها ليست حملة عابرة بل شرط لكل ما نصنعه."
        >
          The mountains gave us this water. Protecting them is not a campaign — it is the condition of
          everything we make.
        </p>
      </div>
      <div class="sustain-points">
        <div class="sustain-point reveal d1">
          <span class="dot"
            ><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
              ><path d="M20 6L9 17l-5-5"></path></svg
            ></span
          >
          <p>
            <b data-en="Lightweight bottles." data-ar="عبوات أخف وزناً.">Lightweight bottles.</b>
            <span
              data-en="Redesigned with less plastic in every cap and body."
              data-ar="أعيد تصميمها لاستخدام بلاستيك أقل في كل غطاء وجسم."
              >Redesigned with less plastic in every cap and body.</span
            >
          </p>
        </div>
        <div class="sustain-point reveal d2">
          <span class="dot"
            ><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
              ><path d="M20 6L9 17l-5-5"></path></svg
            ></span
          >
          <p>
            <b data-en="100% recyclable PET." data-ar="بلاستيك قابل لإعادة التدوير 100%.">100% recyclable PET.</b>
            <span
              data-en="Every bottle is designed to return, not to waste."
              data-ar="كل عبوة مصمّمة لتعود لا لتُهدر."
              >Every bottle is designed to return, not to waste.</span
            >
          </p>
        </div>
        <div class="sustain-point reveal d3">
          <span class="dot"
            ><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
              ><path d="M20 6L9 17l-5-5"></path></svg
            ></span
          >
          <p>
            <b data-en="Water stewardship." data-ar="ترشيد المياه.">Water stewardship.</b>
            <span
              data-en="We draw only what the aquifer can naturally replenish."
              data-ar="لا نستخرج إلا ما يمكن للطبقة الجوفية تعويضه طبيعياً."
              >We draw only what the aquifer can naturally replenish.</span
            >
          </p>
        </div>
      </div>
    </div>
    <div class="sustain-visual media" data-fx="tilt">
      <div class="ph" data-label="The water we protect"></div>
      <img
        class="cover"
        loading="lazy"
        alt="Ocean wave at dusk"
        src="https://images.unsplash.com/photo-1559827260-dc66d52bef19?auto=format&fit=crop&w=1100&q=80"
      />
    </div>
  </div>
</section>
