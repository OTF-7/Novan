---
/* Brand-consistent vector product renders on TRUE transparency — the
   Path-style card effect needs a cut-out bottle, and stock sites can't
   give us licensed transparent PNGs. Four SKUs, one design language. */
interface Props {
  variant: "330" | "600" | "1500" | "19000";
}
const { variant } = Astro.props;

const ink = "oklch(0.40 0.068 248)";
const tealMid = "oklch(0.52 0.075 242)";
const water = "oklch(0.878 0.040 235 / 0.6)";
const waterDeep = "oklch(0.845 0.050 230 / 0.7)";
const body = "oklch(0.99 0.004 92 / 0.5)";
const paper = "oklch(0.98 0.005 92)";
const line = "oklch(0.875 0.012 100)";
const rib = "oklch(0.40 0.068 248 / 0.22)";
---

{
  variant === "330" && (
    <svg viewBox="0 0 120 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="46" y="6" width="28" height="20" rx="5" fill={ink} />
      <rect x="43" y="27" width="34" height="6" rx="3" fill={tealMid} />
      <path
        d="M50 33 h20 v10 c0 6 22 10 22 26 v126 c0 13 -14 20 -32 20 s-32 -7 -32 -20 V69 c0 -16 22 -20 22 -26 Z"
        fill={body}
        stroke={ink}
        stroke-width="3"
      />
      <rect x="32" y="80" width="56" height="120" rx="12" fill={water} />
      <ellipse cx="60" cy="82" rx="26" ry="4" fill="oklch(0.93 0.02 230 / 0.8)" />
      <path d="M30 98 h60 M30 108 h60" stroke={rib} stroke-width="2" />
      <rect x="30" y="118" width="60" height="50" fill={paper} stroke={line} stroke-width="1.5" />
      <path d="M60 124 c-3.6 4.4 -5.6 7.2 -5.6 10 a5.6 5.6 0 0 0 11.2 0 c0 -2.8 -2 -5.6 -5.6 -10 Z" fill={tealMid} />
      <text
        x="60"
        y="158"
        text-anchor="middle"
        font-family="Schibsted Grotesk, sans-serif"
        font-weight="700"
        font-size="10"
        letter-spacing="2"
        fill={ink}>NOVAN</text>
      <path d="M38 78 c-3 4 -4 8 -4 13 v95" stroke="white" stroke-opacity="0.55" stroke-width="4" stroke-linecap="round" />
    </svg>
  )
}

{
  variant === "600" && (
    <svg viewBox="0 0 120 300" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="46" y="6" width="28" height="20" rx="5" fill={ink} />
      <rect x="43" y="27" width="34" height="6" rx="3" fill={tealMid} />
      <path
        d="M50 33 h20 v14 c0 6 20 12 20 30 v196 c0 14 -13 21 -30 21 s-30 -7 -30 -21 V77 c0 -18 20 -24 20 -30 Z"
        fill={body}
        stroke={ink}
        stroke-width="3"
      />
      <rect x="34" y="90" width="52" height="190" rx="12" fill={water} />
      <ellipse cx="60" cy="92" rx="24" ry="4" fill="oklch(0.93 0.02 230 / 0.8)" />
      <path d="M32 120 h56 M32 132 h56" stroke={rib} stroke-width="2" />
      <path d="M32 232 h56 M32 244 h56" stroke={rib} stroke-width="2" />
      <rect x="30" y="152" width="60" height="56" fill={paper} stroke={line} stroke-width="1.5" />
      <path d="M60 159 c-4 4.8 -6.2 8 -6.2 11 a6.2 6.2 0 0 0 12.4 0 c0 -3 -2.2 -6.2 -6.2 -11 Z" fill={tealMid} />
      <text
        x="60"
        y="197"
        text-anchor="middle"
        font-family="Schibsted Grotesk, sans-serif"
        font-weight="700"
        font-size="10.5"
        letter-spacing="2"
        fill={ink}>NOVAN</text>
      <path d="M40 88 c-3 4 -4 9 -4 14 v160" stroke="white" stroke-opacity="0.55" stroke-width="4" stroke-linecap="round" />
    </svg>
  )
}

{
  variant === "1500" && (
    <svg viewBox="0 0 130 330" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="51" y="6" width="28" height="20" rx="5" fill={ink} />
      <rect x="48" y="27" width="34" height="6" rx="3" fill={tealMid} />
      <path
        d="M55 33 h20 v16 c0 7 25 13 25 32 v210 c0 15 -16 22 -35 22 s-35 -7 -35 -22 V81 c0 -19 25 -25 25 -32 Z"
        fill={body}
        stroke={ink}
        stroke-width="3"
      />
      <rect x="34" y="95" width="62" height="210" rx="14" fill={water} />
      <ellipse cx="65" cy="97" rx="29" ry="4.5" fill="oklch(0.93 0.02 230 / 0.8)" />
      <path d="M32 122 h66 M32 134 h66" stroke={rib} stroke-width="2" />
      <path d="M32 252 h66 M32 264 h66" stroke={rib} stroke-width="2" />
      <rect x="30" y="166" width="70" height="62" fill={paper} stroke={line} stroke-width="1.5" />
      <path d="M65 174 c-4.4 5.2 -6.8 8.6 -6.8 12 a6.8 6.8 0 0 0 13.6 0 c0 -3.4 -2.4 -6.8 -6.8 -12 Z" fill={tealMid} />
      <text
        x="65"
        y="216"
        text-anchor="middle"
        font-family="Schibsted Grotesk, sans-serif"
        font-weight="700"
        font-size="11.5"
        letter-spacing="2.2"
        fill={ink}>NOVAN</text>
      <path d="M44 92 c-3 5 -4.5 10 -4.5 15 v175" stroke="white" stroke-opacity="0.55" stroke-width="4.5" stroke-linecap="round" />
    </svg>
  )
}

{
  variant === "19000" && (
    <svg viewBox="0 0 220 270" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="92" y="8" width="36" height="22" rx="5" fill={ink} />
      <rect x="88" y="31" width="44" height="7" rx="3.5" fill={tealMid} />
      <path
        d="M96 38 h28 v9 c0 8 56 14 56 36 v150 c0 18 -22 27 -70 27 s-70 -9 -70 -27 V83 c0 -22 56 -28 56 -36 Z"
        fill={body}
        stroke={ink}
        stroke-width="3.5"
      />
      <rect x="46" y="95" width="128" height="150" rx="18" fill={waterDeep} />
      <ellipse cx="110" cy="98" rx="60" ry="6" fill="oklch(0.93 0.02 230 / 0.8)" />
      <path d="M46 130 h128 M46 150 h128 M46 170 h128" stroke="oklch(1 0 0 / 0.3)" stroke-width="2.5" />
      <rect x="76" y="178" width="68" height="52" fill={paper} stroke={line} stroke-width="1.5" />
      <path d="M110 185 c-4 4.8 -6.2 8 -6.2 11 a6.2 6.2 0 0 0 12.4 0 c0 -3 -2.2 -6.2 -6.2 -11 Z" fill={tealMid} />
      <text
        x="110"
        y="220"
        text-anchor="middle"
        font-family="Schibsted Grotesk, sans-serif"
        font-weight="700"
        font-size="10.5"
        letter-spacing="2"
        fill={ink}>NOVAN</text>
      <path d="M58 102 c-5 7 -7 14 -7 22 v95" stroke="white" stroke-opacity="0.5" stroke-width="5" stroke-linecap="round" />
    </svg>
  )
}
